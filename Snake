name: generate animation

on:
  # run automatically every 24 hours so the snake reflects new contributions
  schedule:
    - cron: "0 0 * * *"
  # lets you trigger it manually from the Actions tab
  workflow_dispatch:
  # run whenever you push to your default branch
  push:
    branches:
      - main

jobs:
  generate:
    permissions:
      contents: write
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - name: generate github-contribution-grid-snake.svg
        uses: Platane/snk/svg-only@v3
        with:
          github_user_name: ${{ github.repository_owner }}
          outputs: |
            dist/github-contribution-grid-snake.svg
            dist/github-contribution-grid-snake-dark.svg?palette=github-dark

      # pushes the generated svg files to the "output" branch
      # they'll then be available at:
      # https://raw.githubusercontent.com/<your-username>/<your-username>/output/<file>
      - name: push github-contribution-grid-snake.svg to the output branch
        uses: crazy-max/ghaction-github-pages@v3.1.0
        with:
          target_branch: output
          build_dir: dist
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
